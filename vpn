#!/usr/bin/env bash
set -e

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/aws-vpn-cli"
# Resolve symlinks to find actual install directory (portable, no readlink -f on macOS)
_resolve_symlink() {
  local target="$1"
  while [[ -L "$target" ]]; do
    local dir="$(cd "$(dirname "$target")" && pwd)"
    target="$(readlink "$target")"
    [[ "$target" != /* ]] && target="$dir/$target"
  done
  echo "$(cd "$(dirname "$target")" && pwd)"
}
INSTALL_DIR="$(_resolve_symlink "${BASH_SOURCE[0]}")"

# Platform detection
OS="$(uname -s)"

if [[ "$OS" == "Darwin" ]]; then
  OVPN_BIN_DEFAULT="/Applications/AWS VPN Client/AWS VPN Client.app/Contents/Resources/openvpn/acvc-openvpn"
  OVPN_BIN_SYMLINK="/usr/local/lib/aws-vpn-cli/acvc-openvpn"
else
  ACVC_OPENVPN="/opt/awsvpnclient/Service/Resources/openvpn/acvc-openvpn"
  OVPN_BIN_WRAPPER="$CONFIG_DIR/acvc-openvpn"
  if [[ -f "$ACVC_OPENVPN" ]]; then
    # acvc-openvpn is a musl-linked binary; if the dynamic loader can't run it
    # directly, create a wrapper that invokes it via the musl interpreter.
    if "$ACVC_OPENVPN" --version > /dev/null 2>&1; then
      OVPN_BIN_DEFAULT="$ACVC_OPENVPN"
    elif [[ -x "/lib/ld-musl-x86_64.so.1" ]]; then
      mkdir -p "$CONFIG_DIR"
      cat > "$OVPN_BIN_WRAPPER" <<'WRAPPER'
#!/bin/sh
exec /lib/ld-musl-x86_64.so.1 /opt/awsvpnclient/Service/Resources/openvpn/acvc-openvpn "$@"
WRAPPER
      chmod +x "$OVPN_BIN_WRAPPER"
      OVPN_BIN_DEFAULT="$OVPN_BIN_WRAPPER"
    else
      OVPN_BIN_DEFAULT="$ACVC_OPENVPN"
    fi
  else
    OVPN_BIN_DEFAULT="/usr/sbin/openvpn"
  fi
  OVPN_BIN_SYMLINK="/usr/local/lib/aws-vpn-cli/acvc-openvpn"
fi
# Prefer the symlink (space-free path works with sudoers NOPASSWD rules)
if [[ -z "${OVPN_BIN:-}" ]]; then
  if [[ -x "$OVPN_BIN_SYMLINK" ]]; then
    OVPN_BIN="$OVPN_BIN_SYMLINK"
  else
    OVPN_BIN="$OVPN_BIN_DEFAULT"
  fi
fi
if [[ -x "$INSTALL_DIR/saml-server" ]]; then
  SAML_SERVER="$INSTALL_DIR/saml-server"
else
  SAML_SERVER="python3 $INSTALL_DIR/saml-server.py"
fi
PROTO=udp
VERSION="0.3.2"

AWS_VPN_CLIENT_PROFILES="$HOME/.config/AWSVPNClient/ConnectionProfiles"
AWS_VPN_CLIENT_CONFIGS="$HOME/.config/AWSVPNClient/OpenVpnConfigs"

# Colors
BOLD='\033[1m'
DIM='\033[2m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
RESET='\033[0m'

info()    { echo -e "${CYAN}>${RESET} $*"; }
step()    { echo -e "${BLUE}==>${RESET}${BOLD} $*${RESET}"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }
warn()    { echo -e "${YELLOW}!${RESET} $*"; }
err()     { echo -e "${RED}✗${RESET} $*" >&2; }

# Per-profile state files
_pid_file() { echo "$CONFIG_DIR/vpn-${1}.pid"; }
_log_file() { echo "$CONFIG_DIR/vpn-${1}.log"; }

_is_profile_connected() {
  local slug="$1"
  local pf
  pf=$(_pid_file "$slug")
  if [[ -f "$pf" ]]; then
    local pid
    pid=$(cat "$pf")
    if ps -p "$pid" > /dev/null 2>&1; then
      return 0
    fi
    # Stale PID file — process died
    rm -f "$pf"
  fi
  return 1
}

_active_profiles() {
  # Return all connected profile slugs, one per line
  ps -eo args= 2>/dev/null | grep -o "aws-vpn-cli/configs/[^ ]*\.conf" | sed 's|.*/||;s|\.conf||' | sort -u
}

_profile_uptime() {
  local slug="$1"
  ps -eo etime=,args= 2>/dev/null | grep "aws-vpn-cli/configs/${slug}\.conf" | grep -v grep | head -1 | awk '{print $1}' | sed 's/^ *//'
}

usage() {
  echo -e "${BOLD}Usage:${RESET} vpn ${DIM}[command]${RESET}"
  echo ""
  echo -e "  ${CYAN}vpn${RESET}                 Select profiles to connect/disconnect"
  echo -e "  ${CYAN}vpn${RESET} ${DIM}<profile>${RESET}       Connect to a profile (or disconnect if connected)"
  echo ""
  echo -e "${BOLD}Commands:${RESET}"
  echo -e "  ${CYAN}status${RESET}              Show connection status"
  echo -e "  ${CYAN}disconnect${RESET} ${DIM}[profile]${RESET} Disconnect from a profile (or select)"
  echo -e "  ${CYAN}list${RESET}                List available profiles"
  echo -e "  ${CYAN}import${RESET}              Import profiles from AWS VPN Client"
  echo -e "  ${CYAN}logs${RESET} ${DIM}[profile]${RESET}      Tail the connection log"
  echo -e "  ${CYAN}setup-sudo${RESET}          Skip password prompts"
  exit "${1:-0}"
}

cmd_import() {
  if [[ ! -f "$AWS_VPN_CLIENT_PROFILES" ]]; then
    err "AWS VPN Client is not installed or has no profiles configured"
    info "Install it from ${CYAN}https://aws.amazon.com/vpn/client-vpn/${RESET}"
    exit 1
  fi

  step "Importing profiles from AWS VPN Client"
  mkdir -p "$CONFIG_DIR/configs"

  export AWS_VPN_CLIENT_PROFILES CONFIG_DIR
  python3 << 'PYEOF'
import json, re, os, sys

profiles_path = os.environ["AWS_VPN_CLIENT_PROFILES"]
config_dir = os.environ["CONFIG_DIR"]

with open(profiles_path) as f:
    data = json.load(f)

profiles = {}
for p in data.get("ConnectionProfiles", []):
    name = p["ProfileName"]
    slug = re.sub(r"[^a-z0-9]+", "-", name.lower()).strip("-")
    config_path = p["OvpnConfigFilePath"]

    if not os.path.exists(config_path):
        print(f"  Skipped: {name} (config not found at {config_path})", file=sys.stderr)
        continue

    with open(config_path) as cf:
        config = cf.read()

    # Extract remote host and port from the config
    remote_match = re.search(r"^remote\s+(\S+)\s+(\d+)", config, re.MULTILINE)
    if not remote_match:
        print(f"  Skipped: {name} (no 'remote' line in config)", file=sys.stderr)
        continue

    host = remote_match.group(1)
    port = int(remote_match.group(2))

    # Strip lines that the vpn script handles itself
    stripped = []
    for line in config.splitlines():
        s = line.strip()
        if re.match(r"^remote\s+\S+\s+\d+", s):
            continue
        if s == "remote-random-hostname":
            continue
        if s == "auth-user-pass":
            continue
        if s.startswith("auth-retry"):
            continue
        stripped.append(line)

    adapted = "\n".join(stripped).strip() + "\n"

    out_path = os.path.join(config_dir, "configs", f"{slug}.conf")
    with open(out_path, "w") as out:
        out.write(adapted)

    profiles[slug] = {
        "name": name,
        "host": host,
        "port": port,
        "endpoint_id": p.get("CvpnEndpointId", ""),
        "region": p.get("CvpnEndpointRegion", ""),
    }
    print(f"  \033[0;32m✓\033[0m {name} \033[2m->\033[0m \033[0;36m{slug}\033[0m")

out_file = os.path.join(config_dir, "profiles.json")
with open(out_file, "w") as f:
    json.dump(profiles, f, indent=2)

print(f"\n\033[0;32m✓\033[0m {len(profiles)} profile(s) imported")
PYEOF
}

_load_profiles() {
  # Outputs "slug|name|region" lines, one per profile
  local profiles_file="$CONFIG_DIR/profiles.json"
  if [[ ! -f "$profiles_file" ]]; then
    return 1
  fi
  python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    profiles = json.load(f)
for slug in sorted(profiles):
    p = profiles[slug]
    print(f\"{slug}|{p['name']}|{p['region']}\")
" "$profiles_file"
}

cmd_list() {
  local lines
  lines=$(_load_profiles) || {
    warn "No profiles found. Run ${CYAN}vpn import${RESET} first."
    exit 1
  }

  if [[ -z "$lines" ]]; then
    info "No profiles found."
    return
  fi

  local active_profiles
  active_profiles=$(_active_profiles)

  local max_w=0
  while IFS='|' read -r slug _ _; do
    (( ${#slug} > max_w )) && max_w=${#slug}
  done <<< "$lines"

  while IFS='|' read -r slug name region; do
    if echo "$active_profiles" | grep -qx "$slug"; then
      printf "  ${GREEN}●${RESET} ${CYAN}%-${max_w}s${RESET}  %s ${DIM}(%s)${RESET}\n" "$slug" "$name" "$region"
    else
      printf "    ${CYAN}%-${max_w}s${RESET}  %s ${DIM}(%s)${RESET}\n" "$slug" "$name" "$region"
    fi
  done <<< "$lines"
}

cmd_select() {
  local lines
  lines=$(_load_profiles 2>/dev/null) || true

  if [[ -z "$lines" ]]; then
    info "No profiles found."
    read -rp "Import from AWS VPN Client? [Y/n] " confirm
    if [[ "$confirm" != [nN] ]]; then
      cmd_import
      lines=$(_load_profiles) || {
        err "Import succeeded but no profiles found"
        exit 1
      }
    else
      exit 0
    fi
  fi

  local slug
  local active_profiles
  active_profiles=$(_active_profiles)

  if command -v fzf > /dev/null 2>&1; then
    local max_w=0
    while IFS='|' read -r s _ _; do
      (( ${#s} > max_w )) && max_w=${#s}
    done <<< "$lines"

    slug=$(echo "$lines" | while IFS='|' read -r s name region; do
      if echo "$active_profiles" | grep -qx "$s"; then
        printf "%-${max_w}s  %s (%s) ${GREEN}● connected${RESET}\n" "$s" "$name" "$region"
      else
        printf "%-${max_w}s  %s (%s)\n" "$s" "$name" "$region"
      fi
    done | fzf --ansi --height=~10 --layout=reverse --prompt="VPN > " --no-info \
      --color="pointer:cyan,prompt:blue,hl:cyan,hl+:cyan,fg+:white:bold,pointer:cyan" | awk '{print $1}')
  else
    # Fallback: bash select
    local -a slugs names
    while IFS='|' read -r s name region; do
      slugs+=("$s")
      if echo "$active_profiles" | grep -qx "$s"; then
        names+=("$name ($region) ● connected")
      else
        names+=("$name ($region)")
      fi
    done <<< "$lines"

    echo -e "${BOLD}Select a profile:${RESET}"
    PS3="> "
    select choice in "${names[@]}"; do
      if [[ -n "$choice" ]]; then
        slug="${slugs[$((REPLY - 1))]}"
        break
      fi
    done
  fi

  if [[ -z "$slug" ]]; then
    info "Cancelled"
    exit 0
  fi

  if _is_profile_connected "$slug"; then
    cmd_disconnect "$slug"
  else
    cmd_connect "$slug"
  fi
}

cmd_status() {
  local active_profiles
  active_profiles=$(_active_profiles)

  if [[ -z "$active_profiles" ]]; then
    info "Not connected"
    return
  fi

  while read -r slug; do
    local uptime
    uptime=$(_profile_uptime "$slug")
    success "Connected to ${BOLD}${slug}${RESET}${uptime:+ ${DIM}(${uptime})${RESET}}"
  done <<< "$active_profiles"
}

_cleanup_stale_dns() {
  local slug="$1"
  if [[ "$OS" == "Darwin" ]]; then
    # Try all possible tun devices for this profile's stale DNS
    for dev in /var/run/utun* /dev/tun*; do
      local dname
      dname=$(basename "$dev" 2>/dev/null) || continue
      echo "show State:/Network/Service/aws-vpn-${dname}/DNS" | scutil 2>/dev/null | grep -q "ServerAddresses" && \
        env -u TERMINFO sudo scutil <<-EOF
	remove State:/Network/Service/aws-vpn-${dname}/DNS
	EOF
    done
  fi
  # On Linux, DNS is per-device and cleaned up when the tun device disappears
}

cmd_disconnect() {
  local slug="${1:-}"

  if [[ -z "$slug" ]]; then
    # No profile specified — pick from connected ones
    local active_profiles
    active_profiles=$(_active_profiles)

    if [[ -z "$active_profiles" ]]; then
      info "Not connected"
      return 0
    fi

    # If only one connection, disconnect it
    local count
    count=$(echo "$active_profiles" | wc -l)
    if (( count == 1 )); then
      slug="$active_profiles"
    elif command -v fzf > /dev/null 2>&1; then
      slug=$(echo "$active_profiles" | fzf --ansi --height=~10 --layout=reverse \
        --prompt="Disconnect > " --no-info \
        --color="pointer:cyan,prompt:blue,hl:cyan,hl+:cyan,fg+:white:bold,pointer:cyan")
    else
      local -a slugs=()
      while read -r s; do slugs+=("$s"); done <<< "$active_profiles"
      echo -e "${BOLD}Disconnect which profile?${RESET}"
      PS3="> "
      select choice in "${slugs[@]}" "all"; do
        if [[ "$choice" == "all" ]]; then
          for s in "${slugs[@]}"; do
            cmd_disconnect "$s"
          done
          return
        elif [[ -n "$choice" ]]; then
          slug="$choice"
          break
        fi
      done
    fi

    if [[ -z "$slug" ]]; then
      info "Cancelled"
      return 0
    fi
  fi

  if ! _is_profile_connected "$slug"; then
    info "${BOLD}${slug}${RESET} is not connected"
    return 0
  fi

  local uptime pf
  uptime=$(_profile_uptime "$slug")
  pf=$(_pid_file "$slug")
  step "Disconnecting from ${slug}"

  # Kill this profile's openvpn process (daemon is named aws-vpn-cli-{slug})
  env -u TERMINFO sudo pkill -f "aws-vpn-cli-${slug}" 2>/dev/null || true
  rm -f "$pf"

  # Wait briefly for the down script to restore DNS
  sleep 1

  # Force-kill if still running
  if pgrep -f "aws-vpn-cli-${slug}" > /dev/null 2>&1; then
    env -u TERMINFO sudo pkill -9 -f "aws-vpn-cli-${slug}" 2>/dev/null || true
  fi
  _cleanup_stale_dns "$slug"

  success "Disconnected from ${BOLD}${slug}${RESET}${uptime:+ ${DIM}(was connected ${uptime})${RESET}}"
}

cmd_logs() {
  local slug="${1:-}"

  if [[ -z "$slug" ]]; then
    local active_profiles
    active_profiles=$(_active_profiles)
    if [[ -n "$active_profiles" ]]; then
      slug=$(echo "$active_profiles" | head -1)
    fi
  fi

  if [[ -z "$slug" ]]; then
    info "No active connection. Specify a profile: ${CYAN}vpn logs <profile>${RESET}"
    exit 1
  fi

  local lf
  lf=$(_log_file "$slug")
  if [[ ! -f "$lf" ]]; then
    info "No log file found for ${BOLD}${slug}${RESET}"
    exit 1
  fi
  tail -f "$lf"
}

cmd_connect() {
  local profile="$1"
  local profiles_file="$CONFIG_DIR/profiles.json"

  if [[ ! -f "$profiles_file" ]]; then
    warn "No profiles yet — run ${CYAN}vpn${RESET} to get started"
    exit 1
  fi

  if _is_profile_connected "$profile"; then
    warn "Already connected to ${BOLD}$profile${RESET}"
    info "Run ${CYAN}vpn disconnect ${profile}${RESET} to disconnect"
    exit 1
  fi

  # Read profile info
  local profile_info
  profile_info=$(python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    profiles = json.load(f)
slug = sys.argv[2]
if slug not in profiles:
    sys.exit(1)
p = profiles[slug]
print(f\"{p['host']}|{p['port']}|{p['name']}\")
" "$profiles_file" "$profile" 2>/dev/null) || {
    err "Unknown profile '${BOLD}$profile${RESET}'"
    echo ""
    info "Available profiles:"
    cmd_list
    exit 1
  }

  local VPN_HOST VPN_PORT PROFILE_NAME
  IFS='|' read -r VPN_HOST VPN_PORT PROFILE_NAME <<< "$profile_info"
  local OVPN_CONF="$CONFIG_DIR/configs/${profile}.conf"

  if [[ ! -f "$OVPN_CONF" ]]; then
    err "Config file missing for ${BOLD}${profile}${RESET}"
    info "Run ${CYAN}vpn import${RESET} to re-import profiles"
    exit 1
  fi

  if [[ ! -x "$OVPN_BIN" ]]; then
    err "AWS VPN Client is not installed"
    info "Install it from ${CYAN}https://aws.amazon.com/vpn/client-vpn/${RESET}"
    exit 1
  fi

  local PID_FILE LOG_FILE
  PID_FILE=$(_pid_file "$profile")
  LOG_FILE=$(_log_file "$profile")

  local RUNTIME_DIR
  RUNTIME_DIR=$(mktemp -d -t aws-vpn.XXXXXX)

  # Kill any stale SAML server from a previous run
  if command -v lsof > /dev/null 2>&1; then
    for pid in $(lsof -ti :35001 2>/dev/null); do
      kill "$pid" 2>/dev/null || true
    done
  else
    fuser -k 35001/tcp 2>/dev/null || true
  fi

  step "Authenticating"
  local SAML_PID=""
  cd "$RUNTIME_DIR"
  $SAML_SERVER &
  SAML_PID=$!
  sleep 0.5

  saml_cleanup() {
    [[ -n "$SAML_PID" ]] && kill "$SAML_PID" 2>/dev/null || true
    rm -rf "$RUNTIME_DIR"
  }
  trap saml_cleanup EXIT

  # Random hostname prefix for the VPN gateway
  local RAND
  RAND=$(openssl rand -hex 12)

  # Resolve hostname to IP (need persistent IP for both connection phases)
  local SRV
  SRV=$(python3 -c "import socket; print(socket.getaddrinfo('${RAND}.${VPN_HOST}', None, socket.AF_INET)[0][4][0])" 2>/dev/null)
  if [[ -z "$SRV" ]]; then
    err "Could not resolve VPN host: ${VPN_HOST}"
    exit 1
  fi

  info "Connecting to ${BOLD}${PROFILE_NAME}${RESET}..."

  local OVPN_OUT
  local retries=3
  while ((retries-- > 0)); do
    OVPN_OUT=$("$OVPN_BIN" --config "$OVPN_CONF" --verb 3 \
        --proto "$PROTO" --remote "${SRV}" "${VPN_PORT}" \
        --server-poll-timeout 10 \
        --auth-user-pass <(printf "%s\n%s\n" "N/A" "ACS::35001") \
        2>&1 | grep AUTH_FAILED,CRV1) || true

    if [[ -n "$OVPN_OUT" ]]; then
      break
    fi

    if ((retries > 0)); then
      warn "No response from server, retrying..."
    fi
  done

  if [[ -z "$OVPN_OUT" ]]; then
    err "Could not reach VPN endpoint"
    info "Check your network connection and try again"
    exit 1
  fi

  step "Opening browser for SSO"
  local URL
  URL=$(echo "$OVPN_OUT" | grep -Eo 'https://.+')
  if [[ "$OS" == "Darwin" ]]; then
    open "$URL"
  else
    xdg-open "$URL" 2>/dev/null || {
      warn "Could not open browser automatically"
      info "Open this URL manually: ${CYAN}${URL}${RESET}"
    }
  fi

  info "Waiting for authentication..."
  local wait_seconds=30
  until test $((wait_seconds--)) -eq 0 -o -f "saml-response.txt"; do sleep 1; done

  if [[ ! -s "saml-response.txt" ]]; then
    err "Authentication timed out"
    exit 1
  fi

  local VPN_SID
  VPN_SID=$(echo "$OVPN_OUT" | awk -F : '{print $7}')

  success "Authenticated"
  step "Establishing tunnel"
  if [[ ! -f /etc/sudoers.d/aws-vpn-cli ]]; then
    info "Password required for tunnel — run ${CYAN}vpn setup-sudo${RESET} to skip"
  fi

  # Write credentials to a temp file
  local AUTH_FILE
  AUTH_FILE=$(mktemp)
  cleanup() {
    [[ -n "$SAML_PID" ]] && kill "$SAML_PID" 2>/dev/null || true
    rm -rf "$RUNTIME_DIR"
    rm -f "$AUTH_FILE"
  }
  trap cleanup EXIT

  printf "%s\n%s\n" "N/A" "CRV1::${VPN_SID}::$(cat saml-response.txt)" > "$AUTH_FILE"
  chmod 600 "$AUTH_FILE"

  # Kill SAML server — no longer needed
  kill "$SAML_PID" 2>/dev/null || true
  SAML_PID=""

  # Start openvpn as a background daemon
  : > "$LOG_FILE"
  env -u TERMINFO sudo "$OVPN_BIN" --config "$OVPN_CONF" \
      --verb 3 --auth-nocache --inactive 3600 \
      --proto "$PROTO" --remote "$SRV" "$VPN_PORT" \
      --script-security 2 \
      --route-up "$INSTALL_DIR/route-up.sh" \
      --down "$INSTALL_DIR/dns-down.sh" \
      --auth-user-pass "$AUTH_FILE" \
      --log "$LOG_FILE" \
      --writepid "$PID_FILE" \
      --daemon "aws-vpn-cli-${profile}"

  # Wait for tunnel to come up
  local attempts=20
  while ((attempts-- > 0)); do
    if _is_profile_connected "$profile"; then
      rm -f "$AUTH_FILE"
      trap - EXIT
      rm -rf "$RUNTIME_DIR"
      success "Connected to ${BOLD}${PROFILE_NAME}${RESET}"
      exit 0
    fi
    sleep 1
  done

  rm -f "$AUTH_FILE"
  trap - EXIT
  rm -rf "$RUNTIME_DIR"
  success "Tunnel started ${DIM}(DNS may take a moment)${RESET}"
}

cmd_setup_sudo() {
  local sudoers_file="/etc/sudoers.d/aws-vpn-cli"
  local symlink_dir="/usr/local/lib/aws-vpn-cli"
  local symlink_path="$symlink_dir/acvc-openvpn"

  if [[ -f "$sudoers_file" ]] && sudo -n "$symlink_path" --version > /dev/null 2>&1; then
    success "Passwordless sudo is already configured"
    info "To remove: sudo rm $sudoers_file $symlink_path"
    return
  fi

  step "Setting up passwordless sudo for vpn"
  info "This will:"
  echo -e "  - Symlink the OpenVPN binary to ${BOLD}${symlink_path}${RESET}"
  if [[ "$OS" == "Darwin" ]]; then
    echo -e "  - Create ${BOLD}${sudoers_file}${RESET} allowing openvpn, pkill, and scutil without a password"
  else
    echo -e "  - Create ${BOLD}${sudoers_file}${RESET} allowing openvpn, pkill, and resolvectl without a password"
  fi
  echo ""

  read -rp "Proceed? [y/N] " confirm
  if [[ "$confirm" != [yY] ]]; then
    info "Cancelled"
    return
  fi

  # Create a symlink at a space-free path (sudoers can't handle spaces in commands)
  sudo mkdir -p "$symlink_dir"
  sudo ln -sf "$OVPN_BIN" "$symlink_path"

  local rule group
  if [[ "$OS" == "Darwin" ]]; then
    group="%staff"
  else
    group="%sudo"
  fi
  if [[ "$OS" == "Darwin" ]]; then
    rule=$(cat <<SUDOERS
# Allow aws-vpn-cli to manage VPN connections without a password
$group ALL=(root) NOPASSWD: $symlink_path *
$group ALL=(root) NOPASSWD: /usr/bin/pkill -f aws-vpn-cli-*
$group ALL=(root) NOPASSWD: /usr/bin/pkill -9 -f aws-vpn-cli-*
$group ALL=(root) NOPASSWD: /usr/sbin/scutil
SUDOERS
)
  else
    rule=$(cat <<SUDOERS
# Allow aws-vpn-cli to manage VPN connections without a password
$group ALL=(root) NOPASSWD: $symlink_path *
$group ALL=(root) NOPASSWD: /usr/bin/pkill -f aws-vpn-cli-*
$group ALL=(root) NOPASSWD: /usr/bin/pkill -9 -f aws-vpn-cli-*
$group ALL=(root) NOPASSWD: /usr/bin/resolvectl
SUDOERS
)
  fi

  echo "$rule" | sudo tee "$sudoers_file" > /dev/null
  sudo chmod 0440 "$sudoers_file"

  # Validate the file — remove it if broken
  if ! sudo visudo -cf "$sudoers_file" > /dev/null 2>&1; then
    sudo rm -f "$sudoers_file"
    err "Generated sudoers file was invalid — removed it"
    err "Please report this issue"
    exit 1
  fi

  success "Password prompts disabled"
}

_is_profile() {
  local profiles_file="$CONFIG_DIR/profiles.json"
  [[ -f "$profiles_file" ]] && python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    profiles = json.load(f)
sys.exit(0 if sys.argv[2] in profiles else 1)
" "$profiles_file" "$1" 2>/dev/null
}

case "${1:-}" in
  import)            cmd_import ;;
  list|ls)           cmd_list ;;
  status)            cmd_status ;;
  disconnect|down)   cmd_disconnect "${2:-}" ;;
  setup-sudo)        cmd_setup_sudo ;;
  logs)              cmd_logs "${2:-}" ;;
  -v|--version)      echo "aws-vpn-cli $VERSION" ;;
  -h|--help)         usage 0 ;;
  "")                cmd_select ;;
  *)
    if _is_profile "$1"; then
      if _is_profile_connected "$1"; then
        cmd_disconnect "$1"
      else
        cmd_connect "$1"
      fi
    else
      err "Unknown command '${BOLD}$1${RESET}' — run ${CYAN}vpn --help${RESET} for usage"
      exit 1
    fi
    ;;
esac
